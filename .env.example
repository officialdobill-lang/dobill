# APP_URL: The URL where this applet is hosted.
APP_URL=

# OFFICIAL_EMAIL: The central Gmail email used to send one-time passcodes (OTPs) and notifications.
OFFICIAL_EMAIL=

# OFFICIAL_EMAIL_PASSWORD: The Google App Password (16-char code) corresponding to the official email above.
OFFICIAL_EMAIL_PASSWORD=

# RESEND_API_KEY: The API key for Resend email dispatch service (https://resend.com).
RESEND_API_KEY=

# RESEND_FROM_EMAIL: The sender address verified on Resend (e.g. "Do Bill <info@yourdomain.com>").
RESEND_FROM_EMAIL=

# MONGODB_URI: MongoDB Atlas connection string (e.g. "mongodb+srv://username:password@cluster.mongodb.net/dobill_db?retryWrites=true&w=majority")
MONGODB_URI=

